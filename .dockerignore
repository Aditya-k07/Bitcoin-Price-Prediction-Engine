# Root .dockerignore
# Exclude large and unnecessary directories from the Docker build context

# Version Control
.git
.gitignore

# Virtual Environments
.venv
venv
env
bin
obj

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# NodeJS (Frontend)
frontend/node_modules/
frontend/dist/
frontend/.next/

# Go (Backend)
go-backend/bin/
go-backend/vendor/

# Data and Models (Handled via volumes)
ml-service/data/
ml-service/saved_models/
ml-service/app/__pycache__/
ml-service/models/__pycache__/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Docker / Logs
docker-compose.override.yml
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
